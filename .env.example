# Usage Monitor 환경변수 설정
# 이 파일을 .env.local로 복사하여 사용하세요.

# 초기 관리자 계정 (첫 실행 시 자동 생성, 이후 DB에서 관리)
# 비밀번호는 반드시 8자 이상
MONITOR_ADMIN_USER=admin
MONITOR_ADMIN_PASS=your-secure-password-here

# 세션 서명 시크릿 (필수, openssl rand -hex 32 로 생성)
MONITOR_SESSION_SECRET=

# 저장소 암호화 키 (32바이트 hex, 필수)
# openssl rand -hex 32 로 생성 가능
MONITOR_ENCRYPTION_KEY=

# 로그인 세션 쿠키 secure 플래그 강제 설정 (선택)
# true: 항상 secure, false: 항상 non-secure, 미설정: 요청 프로토콜(https/http)에 따라 자동
# MONITOR_COOKIE_SECURE=

# 프록시 신뢰 여부 (선택)
# true로 설정하면 로그인 rate-limit 키 계산 시 전달 IP 헤더 사용을 시도
# TRUST_PROXY=true

# TRUST_PROXY=true일 때 전달 헤더 신뢰를 위한 공유 시크릿 (선택 권장)
# 리버스 프록시에서 x-monitor-proxy-secret 헤더로 같은 값을 전달해야 함
# TRUST_PROXY_SHARED_SECRET=

# 로그 레벨 (debug | info | warn | error, 기본: production=info, dev=debug)
# LOG_LEVEL=info
